# Replay pipeline — copy to `.env` (gitignored) at repo root.
# Loaded automatically by `python -m dungeon_runner.replay.cli` (python-dotenv).

# --- ingest (live RTDB v1) ---
# Required for `ingest` without `--from-export`. Same value as portfolio-site
# VITE_FIREBASE_DATABASE_URL. Other FIREBASE_* client vars are not read until
# authenticated RTDB access is needed.
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# --- verify / dataset (not required for ingest-only) ---
# PORTFOLIO_SITE_ROOT=/path/to/portfolio-site
